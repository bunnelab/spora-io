def build_normalizer(
    *,
    normalization: str,
    crop_size: int,
    modality_dir: str | Path,
    channels_per_image: pd.DataFrame,
    apply_gaussian: bool = False,
    apply_median: bool = False,
    gaussian_blur: Optional[Callable[[torch.Tensor], torch.Tensor]] = None,
    median_filter_fn: Optional[Callable[[torch.Tensor], torch.Tensor]] = None,
    disable_quantile_mask: bool = False,
    append_suffix_to_crop: bool = False,
) -> Tuple["BaseNormalizer", Dict[str, str]]:
    """
    Unified factory that merges get_normalize_metadata(...) and
    build_normalizer_from_metadata(...).

    Returns:
        normalizer: instantiated BaseNormalizer
        info: {
            "crop_folder_name": <str>,
            "channel_file_name": <str>,
        }
    """

    # Preserve prior behavior for 'no_overlap_' crop strategies

    # Common kwargs for all normalizers
    kwargs_common = dict(
        modality_dir=modality_dir,
        channels_per_image=channels_per_image,
        apply_gaussian=apply_gaussian,
        apply_median=apply_median,
        gaussian_blur=gaussian_blur,
        median_filter_fn=median_filter_fn,
        disable_quantile_mask=disable_quantile_mask,
    )

    norm = normalization.strip()

    # Config derived from your corrected metadata mapping
    cfg: Dict[str, Dict[str, str]] = {
        "global_std": {
            "crop_suffix": "",
            "channel_file_name": "channels",
            "mean_name": "mean",
            "std_name": "std",
            # default if not present in legacy metadata
            "quantile_path": "quantiles/q99.csv",
            "ctor": "GlobalStdNormalizer",
        },
        "tm_local_q_global_std": {
            "crop_suffix": "_no_log",
            "channel_file_name": "channels",
            "means_path": "quantiles/tm_clip99/global_level_means.csv",
            "stds_path": "quantiles/tm_clip99/global_level_stds.csv",
            "quantile_path": "quantiles/tm_clip99/image_level_quantiles.csv",
            "ctor": "TMLocalQGlobalStdNormalizer",
        },
        "q99_mean_std": {
            "crop_suffix": "_no_log",
            "channel_file_name": "channels",
            "means_path": "quantiles/0.99/means.csv",
            "stds_path": "quantiles/0.99/stds.csv",
            "quantile_path": "quantiles/0.99/quantiles.csv",
            "ctor": "Q99MeanStdNormalizer",
        },
        # Back-compat alias: behave like global_std but force q99 table path
        "q_99": {
            "crop_suffix": "_no_log",
            "channel_file_name": "channels",
            "mean_name": "mean",
            "std_name": "std",
            "quantile_path": "quantiles/q99.csv",
            "ctor": "GlobalStdNormalizer",
        },
        "identity": {
            "crop_suffix": "",
            "channel_file_name": "channels",
            "ctor": "IdentityNormalizer",
        },
    }

    if norm == "he":
        # Keep explicit to avoid silently constructing a multiplex normalizer
        raise NotImplementedError(
            "H&E normalization ('he') is handled separately (no multiplex normalizer to build)."
        )

    if norm not in cfg:
        raise NotImplementedError(f"Normalization '{norm}' not implemented")

    c = cfg[norm]
    channel_file_name = c["channel_file_name"]
    ctor_name = c["ctor"]

    # Resolve constructor
    ctor_map = {
        "GlobalStdNormalizer": GlobalStdNormalizer,
        "TMLocalQGlobalStdNormalizer": TMLocalQGlobalStdNormalizer,
        "Q99MeanStdNormalizer": Q99MeanStdNormalizer,
        "Q99Normalizer": Q99Normalizer,
        "IdentityNormalizer": IdentityNormalizer,
    }
    ctor = ctor_map[ctor_name]

    # Instantiate with the appropriate signature
    if ctor in (GlobalStdNormalizer,):
        normalizer = ctor(
            channel_file_name=channel_file_name,
            mean_name=c["mean_name"],
            std_name=c["std_name"],
            quantile_path=c.get("quantile_path", "quantiles/q99.csv"),
            **kwargs_common,
        )
    elif ctor in (
        TMLocalQGlobalStdNormalizer,
        Q99MeanStdNormalizer,
    ):
        normalizer = ctor(
            quantile_path=c["quantile_path"],
            means_path=c["means_path"],
            stds_path=c["stds_path"],
            **kwargs_common,
        )
    elif ctor in (Q99Normalizer, IdentityNormalizer):
        normalizer = ctor(
            quantile_path=c.get("quantile_path", "quantiles/q99.csv"),
            **kwargs_common,
        )
    else:
        raise RuntimeError(f"Unknown constructor '{ctor_name}'")

    return normalizer